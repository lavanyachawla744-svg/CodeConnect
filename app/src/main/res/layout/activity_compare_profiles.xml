<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ── Top App Bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_card"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/text_secondary"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Compare Profiles"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 0 – Platform Selection                                       -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/stepSelectLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="top">

        <!-- GitHub (fixed, always selected) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLATFORM A  (fixed)"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/github"
            app:strokeWidth="3dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_icon_bg"
                    android:backgroundTint="@color/github"
                    android:gravity="center"
                    android:text="{ }"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GitHub"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Repos · Stars · Followers"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="@color/github"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Platform B heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLATFORM B  (choose one)"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <!-- LeetCode option -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectLeetCode"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/leetcode"
            app:strokeWidth="1dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_icon_bg"
                    android:backgroundTint="@color/leetcode"
                    android:gravity="center"
                    android:text="LC"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LeetCode"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Easy · Medium · Hard · Ranking"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="@color/leetcode"
                    android:textSize="22sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CodeChef option -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectCodeChef"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/codechef"
            app:strokeWidth="1dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_icon_bg"
                    android:backgroundTint="@color/codechef"
                    android:gravity="center"
                    android:text="CC"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CodeChef"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rating · Stars · Global Rank"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="@color/codechef"
                    android:textSize="22sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout><!-- /stepSelectLayout -->

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 1 – Username Input                                           -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/stepInputLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter Usernames"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We'll fetch live data from each platform."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="28dp" />

        <!-- GitHub username -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GitHub Username"
            android:textColor="@color/github"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etGithubUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/input_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="e.g. torvalds"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:inputType="textNoSuggestions"
            android:singleLine="true"
            android:layout_marginBottom="20dp" />

        <!-- Platform B username -->
        <TextView
            android:id="@+id/tvPlatformBLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Platform Username"
            android:textColor="@color/leetcode"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etPlatformBUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/input_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="Enter username"
            android:inputType="textNoSuggestions"
            android:singleLine="true"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvPlatformBHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter username"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginBottom="28dp" />

        <!-- Error text -->
        <TextView
            android:id="@+id/tvFetchError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressFetch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- Fetch button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFetch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Compare Profiles"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp" />

    </LinearLayout><!-- /stepInputLayout -->

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- STEP 2 – Results                                                  -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/stepResultsLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Results title: "GitHub vs LeetCode" -->
            <TextView
                android:id="@+id/tvResultsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GitHub  vs  LeetCode"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <!-- ── GitHub profile card ──────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/github"
                app:strokeWidth="2dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/circle_icon_bg"
                            android:backgroundTint="@color/github"
                            android:gravity="center"
                            android:text="{ }"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvGhUsername"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@—"
                                android:textColor="@color/text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvGhBio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No bio"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:maxLines="2"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Stats grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:id="@+id/tvGhRepos" android:text="0"
                                android:textColor="@color/github" android:textSize="22sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Repos" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:id="@+id/tvGhStars" android:text="0"
                                android:textColor="@color/chart_yellow" android:textSize="22sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Stars" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:id="@+id/tvGhForks" android:text="0"
                                android:textColor="@color/chart_blue" android:textSize="22sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Forks" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:id="@+id/tvGhFollowers" android:text="0"
                                android:textColor="@color/chart_pink" android:textSize="22sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Followers" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:id="@+id/tvGhFollowing" android:text="0"
                                android:textColor="@color/chart_green" android:textSize="22sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Following" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center" />
                    </LinearLayout>

                    <!-- Score chip -->
                    <TextView
                        android:id="@+id/tvGhScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_background"
                        android:backgroundTint="@color/github"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Score: 0 / 100"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- VS badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VS"
                android:textColor="@color/accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/vs_badge_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="12dp" />

            <!-- ── Platform B profile card ──────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/leetcode"
                app:strokeWidth="2dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvPbUsername"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@—"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 5 dynamic stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Row 1 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:id="@+id/tvPbStat1Val" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textColor="@color/primary" android:textSize="22sp" android:textStyle="bold" />
                                <TextView android:id="@+id/tvPbStat1Label" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="Stat 1"
                                    android:textColor="@color/text_secondary" android:textSize="11sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:id="@+id/tvPbStat2Val" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textColor="@color/easy" android:textSize="22sp" android:textStyle="bold" />
                                <TextView android:id="@+id/tvPbStat2Label" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="Stat 2"
                                    android:textColor="@color/text_secondary" android:textSize="11sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:id="@+id/tvPbStat3Val" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textColor="@color/medium" android:textSize="22sp" android:textStyle="bold" />
                                <TextView android:id="@+id/tvPbStat3Label" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="Stat 3"
                                    android:textColor="@color/text_secondary" android:textSize="11sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row 2 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="14dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:id="@+id/tvPbStat4Val" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textColor="@color/hard" android:textSize="22sp" android:textStyle="bold" />
                                <TextView android:id="@+id/tvPbStat4Label" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="Stat 4"
                                    android:textColor="@color/text_secondary" android:textSize="11sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <TextView android:id="@+id/tvPbStat5Val" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="0"
                                    android:textColor="@color/chart_purple" android:textSize="22sp" android:textStyle="bold" />
                                <TextView android:id="@+id/tvPbStat5Label" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="Stat 5"
                                    android:textColor="@color/text_secondary" android:textSize="11sp" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Score chip + info button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvPbScore"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/chip_background"
                            android:backgroundTint="@color/primary"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:text="Score: 0 / 100"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- ℹ️ Info button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnInfoScore"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="ℹ️ How?"
                            android:textSize="13sp"
                            app:strokeColor="@color/primary"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Winner card ──────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card_elevated"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="2dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvWinnerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆  Winner"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Compare another -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompareAnother"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Compare Another"
                android:textSize="15sp"
                app:backgroundTint="@color/bg_surface"
                app:cornerRadius="14dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView><!-- /stepResultsLayout -->

</LinearLayout>
