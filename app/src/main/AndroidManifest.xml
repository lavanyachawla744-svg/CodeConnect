<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CodeConnect"
        android:usesCleartextTraffic="true">

        <!-- Welcome / Splash Screen -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.CodeConnect.Welcome">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Sign In Screen -->
        <activity
            android:name=".SignInActivity"
            android:exported="false" />

        <!-- Dashboard Screen -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false" />

        <!-- Student Profile Compare Screen -->
        <activity
            android:name=".StudentProfileCompareActivity"
            android:exported="false" />

        <!-- Resume Builder Screen -->
        <activity
            android:name=".ResumeBuilderActivity"
            android:exported="false" />

        <!-- Skill Analytics Screen -->
        <activity
            android:name=".SkillAnalyticsActivity"
            android:exported="false" />

        <!-- Compare (LeetCode) Screen -->
        <activity
            android:name=".CompareActivity"
            android:exported="false" />

        <!-- Profile Compare Screen -->
        <activity
            android:name=".ProfileCompareActivity"
            android:exported="false" />

        <!-- Compare Profiles Screen -->
        <activity
            android:name=".CompareProfilesActivity"
            android:exported="false" />

    </application>

</manifest>
